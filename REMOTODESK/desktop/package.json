{
  "name": "remotedesk-desktop",
  "version": "1.0.0",
  "description": "Electron wrapper for RemoteDesk client",
  "main": "main.js",
  "scripts": {
    "electron:dev": "concurrently \"npm:start\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.remotedesk.app",
    "productName": "RemoteDesk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "../client/dist/**/*",
      "main.js"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
